<mxfile host="app.diagrams.net">
  <diagram id="behavioral" name="Behavioral Comparison">
    <mxGraphModel dx="1000" dy="520" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="460" math="0" shadow="0" background="#ffffff">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Header -->
        <mxCell id="h1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="860" height="200" as="geometry" />
        </mxCell>
        <mxCell id="h1-title" value="CSS クラスが変わった（構造の変化）" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#333333;" vertex="1" parent="h1">
          <mxGeometry x="10" y="5" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Playwright - structure change -->
        <mxCell id="pw-s" value="Playwright&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;getBySelector('.btn-primary')&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=0;shadow=1;" vertex="1" parent="h1">
          <mxGeometry x="30" y="50" width="250" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pw-s-result" value="❌ 壊れる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="h1">
          <mxGeometry x="30" y="130" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="pw-s-arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#b85450;" edge="1" source="pw-s" target="pw-s-result" parent="h1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- claude-test - structure change -->
        <mxCell id="ct-s" value="claude-test&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;AI がスナップショットから再解決&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=0;shadow=1;" vertex="1" parent="h1">
          <mxGeometry x="560" y="50" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ct-s-result" value="✅ 通る" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="h1">
          <mxGeometry x="560" y="130" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ct-s-arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#82b366;" edge="1" source="ct-s" target="ct-s-result" parent="h1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- VS -->
        <mxCell id="vs1" value="vs" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#999999;" vertex="1" parent="h1">
          <mxGeometry x="400" y="55" width="40" height="40" as="geometry" />
        </mxCell>

        <!-- Second row -->
        <mxCell id="h2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="860" height="200" as="geometry" />
        </mxCell>
        <mxCell id="h2-title" value="ボタンのラベルが変わった（振る舞いの変化）" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#333333;" vertex="1" parent="h2">
          <mxGeometry x="10" y="5" width="340" height="30" as="geometry" />
        </mxCell>

        <!-- Playwright - behavioral change -->
        <mxCell id="pw-b" value="Playwright&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;getByRole('button', {name: '確認する'})&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=0;shadow=1;" vertex="1" parent="h2">
          <mxGeometry x="30" y="50" width="250" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pw-b-result" value="❌ 検知できる（正しい動作）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="h2">
          <mxGeometry x="30" y="130" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="pw-b-arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#82b366;" edge="1" source="pw-b" target="pw-b-result" parent="h2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- claude-test - behavioral change -->
        <mxCell id="ct-b" value="claude-test&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;AI が文脈から推測して「次へ進む」を押す&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=0;shadow=1;" vertex="1" parent="h2">
          <mxGeometry x="560" y="50" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ct-b-result" value="✅ 通ってしまう（見逃し）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="h2">
          <mxGeometry x="560" y="130" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ct-b-arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#b85450;" edge="1" source="ct-b" target="ct-b-result" parent="h2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- VS -->
        <mxCell id="vs2" value="vs" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#999999;" vertex="1" parent="h2">
          <mxGeometry x="400" y="55" width="40" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
