<mxfile host="app.diagrams.net">
  <diagram id="app-flow" name="App Flow">
    <mxGraphModel dx="900" dy="400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="340" math="0" shadow="0" background="#ffffff">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Input screen -->
        <mxCell id="input" value="入力画面&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;お名前・メール・カテゴリ&lt;br&gt;お問い合わせ内容&lt;br&gt;バリデーション&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;shadow=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Confirm screen -->
        <mxCell id="confirm" value="確認画面&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;入力内容の表示&lt;br&gt;送信 / 戻る&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;shadow=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="60" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Complete screen -->
        <mxCell id="complete" value="完了画面&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;受付番号表示&lt;br&gt;新しいお問い合わせ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;shadow=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="60" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Forward arrows -->
        <mxCell id="a1" value="確認する" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#545B64;fontSize=10;fontColor=#545B64;" edge="1" source="input" target="confirm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="送信する" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#545B64;fontSize=10;fontColor=#545B64;" edge="1" source="confirm" target="complete" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Back arrow -->
        <mxCell id="a3" value="戻る" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#b85450;dashed=1;fontSize=10;fontColor=#b85450;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" source="confirm" target="input" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="410" y="230" />
              <mxPoint x="140" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Reset arrow -->
        <mxCell id="a4" value="新しいお問い合わせ" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#82b366;dashed=1;fontSize=10;fontColor=#82b366;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" source="complete" target="input" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="280" />
              <mxPoint x="140" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
