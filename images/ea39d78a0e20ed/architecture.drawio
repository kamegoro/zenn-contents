<mxfile host="app.diagrams.net">
  <diagram id="architecture" name="Architecture">
    <mxGraphModel dx="1200" dy="450" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="380" math="0" shadow="0" background="#ffffff">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- YAML -->
        <mxCell id="yaml" value="YAML&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;テストケース&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="140" width="130" height="70" as="geometry" />
        </mxCell>

        <!-- Processor -->
        <mxCell id="processor" value="yaml-test-processor.js&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;パース・展開・変数置換&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="140" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Claude Code -->
        <mxCell id="claude" value="Claude Code&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;ステップを解釈・推論&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="100" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- Playwright MCP -->
        <mxCell id="playwright" value="Playwright MCP&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;ブラウザ操作&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="100" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- Browser -->
        <mxCell id="browser" value="ブラウザ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="140" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- Snapshot return -->
        <mxCell id="snapshot-box" value="アクセシビリティ&lt;br&gt;スナップショット&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;要素 + ref_id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=11;fontStyle=0;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="240" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#545B64;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="yaml" target="processor" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#545B64;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="processor" target="claude" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="ref_id で操作" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#6c8ebf;fontSize=10;" edge="1" source="claude" target="playwright" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#545B64;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="playwright" target="browser" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Snapshot feedback loop -->
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#999999;dashed=1;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" source="browser" target="snapshot-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#999999;dashed=1;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" source="snapshot-box" target="claude" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
